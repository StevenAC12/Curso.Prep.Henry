<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Tarjeta de frecuencia principal -->
        <androidx.cardview.widget.CardView
            style="@style/RadioCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Indicador de banda -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_fm"
                        style="@style/RadioButton"
                        android:layout_width="80dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/radio_fm" />

                    <Button
                        android:id="@+id/btn_am"
                        style="@style/RadioButton.Secondary"
                        android:layout_width="80dp"
                        android:layout_marginStart="8dp"
                        android:text="@string/radio_am" />

                </LinearLayout>

                <!-- Display de frecuencia -->
                <TextView
                    android:id="@+id/tv_frequency"
                    style="@style/FrequencyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="16dp"
                    tools:text="101.5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MHz"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <!-- Indicador de señal -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Señal:"
                        android:textColor="@color/text_secondary" />

                    <ProgressBar
                        android:id="@+id/pb_signal_strength"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="100dp"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="75"
                        android:progressTint="@color/radio_signal_strong" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Controles de sintonización -->
        <androidx.cardview.widget.CardView
            style="@style/RadioCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Sintonización"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Botones de sintonización fina -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_freq_down"
                        style="@style/RadioButton.Secondary"
                        android:layout_width="60dp"
                        android:layout_marginEnd="16dp"
                        android:text="−" />

                    <SeekBar
                        android:id="@+id/seekbar_frequency"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="200"
                        android:progress="30"
                        android:progressTint="@color/primary"
                        android:thumbTint="@color/accent" />

                    <Button
                        android:id="@+id/btn_freq_up"
                        style="@style/RadioButton.Secondary"
                        android:layout_width="60dp"
                        android:layout_marginStart="16dp"
                        android:text="+" />

                </LinearLayout>

                <!-- Botón de búsqueda -->
                <Button
                    android:id="@+id/btn_scan"
                    style="@style/RadioButton.Accent"
                    android:layout_width="match_parent"
                    android:layout_marginTop="16dp"
                    android:text="@string/radio_scan" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Presets -->
        <androidx.cardview.widget.CardView
            style="@style/RadioCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Emisoras Guardadas"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_presets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="6"
                    tools:listitem="@layout/item_radio_preset" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Controles de audio -->
        <androidx.cardview.widget.CardView
            style="@style/RadioCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="@string/radio_volume"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_volume_down"
                        android:tint="@color/text_secondary"
                        tools:ignore="UseAppTint" />

                    <SeekBar
                        android:id="@+id/seekbar_volume"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="50"
                        android:progressTint="@color/primary"
                        android:thumbTint="@color/accent" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_volume_up"
                        android:tint="@color/text_secondary"
                        tools:ignore="UseAppTint" />

                    <Button
                        android:id="@+id/btn_mute"
                        style="@style/RadioButton.Secondary"
                        android:layout_width="80dp"
                        android:layout_marginStart="16dp"
                        android:text="@string/radio_mute" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>